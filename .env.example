# ── Datadog ───────────────────────────────────────────────
DD_API_KEY=sua_api_key_aqui
DD_APP_KEY=sua_app_key_aqui
DD_SITE=datadoghq.com          # ou datadoghq.eu para região EU

# ── AWS ───────────────────────────────────────────────────
AWS_REGION=us-east-1
S3_BUCKET=seu-bucket-datadog-datalake
# Credenciais via IAM Role (recomendado) ou variáveis:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ── Databricks ────────────────────────────────────────────
DATABRICKS_HOST=https://sua-workspace.azuredatabricks.net
DATABRICKS_TOKEN=seu_token_aqui
